#include <stdio.h>
#include <string.h>
#include <limits.h>

void minWindow(char s[], char t[]) {
    int hash[256] = {0};

    int lenS = strlen(s);
    int lenT = strlen(t);

    for (int i = 0; i < lenT; i++)
        hash[t[i]]++;

    int left = 0, count = 0;
    int minLen = INT_MAX, start = 0;

    for (int right = 0; right < lenS; right++) {

        if (hash[s[right]] > 0)
            count++;

        hash[s[right]]--;

        while (count == lenT) {

            if (right - left + 1 < minLen) {
                minLen = right - left + 1;
                start = left;
            }

            hash[s[left]]++;

            if (hash[s[left]] > 0)
                count--;

            left++;
        }
    }

    if (minLen == INT_MAX)
        printf("");
    else {
        for (int i = start; i < start + minLen; i++)
            printf("%c", s[i]);
    }
}

int main() {
    char s[] = "ADOBECODEBANC";
    char t[] = "ABC";

    minWindow(s, t); // Output: BANC
    return 0;
}
