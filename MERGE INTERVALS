#include <stdio.h>

void sort(int arr[][2], int n) {
    for(int i=0;i<n;i++) {
        for(int j=i+1;j<n;j++) {
            if(arr[i][0] > arr[j][0]) {
                int t1 = arr[i][0], t2 = arr[i][1];
                arr[i][0] = arr[j][0];
                arr[i][1] = arr[j][1];
                arr[j][0] = t1;
                arr[j][1] = t2;
            }
        }
    }
}

void mergeIntervals(int arr[][2], int n) {
    sort(arr,n);

    int start = arr[0][0], end = arr[0][1];

    for(int i=1;i<n;i++) {
        if(arr[i][0] <= end) {
            if(arr[i][1] > end)
                end = arr[i][1];
        } else {
            printf("[%d,%d] ", start, end);
            start = arr[i][0];
            end = arr[i][1];
        }
    }
    printf("[%d,%d]", start, end);
}

int main() {
    int arr[][2] = {{1,3},{2,6},{8,10},{15,18}};
    int n = 4;

    mergeIntervals(arr,n);
    return 0;
}
