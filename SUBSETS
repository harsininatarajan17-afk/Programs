#include <stdio.h>

void printSubset(int arr[], int subset[], int size) {
    printf("[");
    for(int i=0;i<size;i++)
        printf("%d ", subset[i]);
    printf("]\n");
}

void subsets(int arr[], int n, int index, int subset[], int size) {
    if(index == n) {
        printSubset(arr, subset, size);
        return;
    }

    // include
    subset[size] = arr[index];
    subsets(arr, n, index+1, subset, size+1);

    // exclude
    subsets(arr, n, index+1, subset, size);
}

int main() {
    int arr[] = {1,2,3};
    int subset[10];
    subsets(arr, 3, 0, subset, 0);
    return 0;
}
