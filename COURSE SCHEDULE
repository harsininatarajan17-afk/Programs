#include <stdio.h>
#include <stdbool.h>

#define MAX 100

int graph[MAX][MAX], visited[MAX], recStack[MAX];

bool dfs(int v, int n) {
    if(recStack[v]) return true;
    if(visited[v]) return false;

    visited[v] = 1;
    recStack[v] = 1;

    for(int i=0;i<n;i++) {
        if(graph[v][i]) {
            if(dfs(i,n))
                return true;
        }
    }

    recStack[v] = 0;
    return false;
}

int canFinish(int n) {
    for(int i=0;i<n;i++) {
        if(dfs(i,n))
            return 0; // cycle
    }
    return 1;
}

int main() {
    int n = 2;

    // prerequisite [1,0]
    graph[1][0] = 1;

    printf("%s", canFinish(n) ? "true" : "false");

    return 0;
}
