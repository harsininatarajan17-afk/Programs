#include <stdio.h>

#define MAX 100

int main() {
    int nums[] = {1,1,1,2,2,3};
    int n = 6, k = 2;

    int freq[MAX] = {0};

    for(int i=0;i<n;i++)
        freq[nums[i]]++;

    for(int i=0;i<k;i++) {
        int max = 0, index = -1;

        for(int j=0;j<MAX;j++) {
            if(freq[j] > max) {
                max = freq[j];
                index = j;
            }
        }

        printf("%d ", index);
        freq[index] = 0;
    }

    return 0;
}
